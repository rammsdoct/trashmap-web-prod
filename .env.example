# PresaWatch Web — copy this to .env.local and fill in real values
# NEVER commit .env.local

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=presawatch.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=presawatch
VITE_FIREBASE_STORAGE_BUCKET=presawatch.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Web client ID from Google Cloud Console (type 3)
VITE_GOOGLE_SIGNIN_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# Google Maps JavaScript API key (restrict to HTTP referrers for your domain)
VITE_GOOGLE_MAPS_API_KEY=your_maps_api_key

# Azure backend API base URL (same as mobile)
VITE_API_URL=https://trashmap-api-presamordor-e0csfsedadffd9ey.canadacentral-01.azurewebsites.net/reports
